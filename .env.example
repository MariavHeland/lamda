# LAMDA — environment variables
# Copy this file to .env.local and fill in real values.

# REQUIRED — Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=sk-ant-api03-...

# REQUIRED IN PRODUCTION — password for the login gate
# If unset, falls back to the default in app/api/auth/route.ts for local dev.
# In production (Vercel) always set this to something strong.
LAMDA_PASSWORD=change-me-before-deploying

# OPTIONAL — DA SUITE integration
# When true, LAMDA appends a SUITE HANDOFF block to each analysis and
# dispatches it to MINDA and GUIDA. Set to false for standalone use.
LAMDA_SUITE=false

# OPTIONAL — Sibling app URLs (defaults shown)
# Used by /api/suite-handoff when Suite mode is active.
MINDA_API_URL=http://localhost:3002/api
GUIDA_API_URL=http://localhost:3000/api

# OPTIONAL — Shared secret for inter-app authentication
# Must match the secret configured in MINDA and GUIDA.
INTER_SERVICE_SECRET=change-me-to-a-shared-secret

# OPTIONAL — Language configuration (can also be set per-request)
# LAMDA_LANG_DUAL=true
# LAMDA_LANG_PRIMARY=sv
# LAMDA_LANG_TERMS=en
